
set nocompatible " make vim more useful
set backspace=indent,eol,start " make backspace work the way you want it to

set title        " sets the title of the window to the filename being edited
set showmode     " shows whether in Insert/Replace/Visual mode at the bottom of the screen
set showcmd      " Show (partial) command at the bottom of the screen
set showmatch    " Shows matching brackets
set nowrap       " Turns off line wrapping
set tabstop=4    " visual spaces per tab
set softtabstop=4  " spaces per tab when editing
set shiftwidth=4 " number of spaces to use for each step of (auto)indent
set expandtab    " use spaces for tab
set number       " show line numbers
set cursorline   " highlight current line
set hlsearch     " highlight searches

